rules_version = '2';

// =============================================================================
// ConvoHub Firestore Security Rules
//
// SECURITY MODEL
// - Roles live on `users/{uid}` documents and are NEVER writable from the client
//   except by webmasters. The `role` field is locked down here, and the
//   `enforceUserRoleOnWrite` Cloud Function provides defense-in-depth by
//   stripping any client-supplied `role` field on every write.
// - Only authenticated users can read/write their own profile. Webmasters can
//   read any profile and are the only principals allowed to mutate roles.
// - Audit collections (`login_attempts`, `noteAudit`, `peopleAudit`,
//   `retentionAudit`) are append-only for clients; deletes/clears are gated to
//   authenticated users (admins/webmasters use the UI controls).
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // -------- Helpers --------
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Webmaster check uses the user's own profile doc. Safe from recursion
    // because we only read users/{auth.uid} (no policy back-reference loop).
    function isWebmaster() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'webmaster';
    }

    // True when the incoming write does NOT touch the `role` field, OR the
    // value being written matches what's already there.
    function roleUnchanged() {
      return !('role' in request.resource.data)
        || (resource != null && resource.data.role == request.resource.data.role);
    }

    // Same idea for the `escalatedAccess` field — only webmasters may toggle
    // expanded access for an admin.
    function escalatedAccessUnchanged() {
      return !('escalatedAccess' in request.resource.data)
        || (resource != null
            && resource.data.get('escalatedAccess', false) == request.resource.data.escalatedAccess);
    }

    // -------- users/{uid} --------
    // Users can read & write their own profile, but cannot set or change
    // `role` or `escalatedAccess`. Webmasters can read any profile and are
    // the only ones allowed to write those privileged fields.
    match /users/{uid} {
      // Any signed-in teammate can read profiles (used to render assignee
      // names in /agents, /conversations, /agent-logs, /analytics, and to
      // fan-out broadcast notifications).
      allow read: if isSignedIn();

      // Create: self-signup. The Cloud Function strips role; rules also forbid
      // a client-supplied non-default role unless the caller is a webmaster.
      allow create: if isSelf(uid)
        && (
          !('role' in request.resource.data)
          || request.resource.data.role == 'agent'
          || request.resource.data.role == 'admin'
          || isWebmaster()
        )
        && !('escalatedAccess' in request.resource.data);

      // Update: self can update profile fields but cannot mutate `role`
      // or `escalatedAccess`. Webmasters can update anything.
      allow update: if (isSelf(uid) && roleUnchanged() && escalatedAccessUnchanged())
        || isWebmaster();

      // Delete: webmaster only.
      allow delete: if isWebmaster();
    }

    // -------- conversations + messages + notes --------
    match /conversations/{convoId} {
      allow read, write: if isSignedIn();
      match /messages/{msgId} {
        allow read, write: if isSignedIn();
      }
      // Conversation notes — shared annotations visible to the whole team.
      // Any signed-in teammate can create/read/edit a note. Deletes are
      // restricted to admins and webmasters so agents can't accidentally
      // erase context the rest of the team relies on. UI mirrors this by
      // hiding the trash button for plain agents.
      match /notes/{noteId} {
        allow read, create, update: if isSignedIn();
        allow delete: if isSignedIn() && (
          (
            exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && (
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'webmaster'
              || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
            )
          )
        );
      }
    }

    // -------- people --------
    match /people/{personId} {
      allow read, write: if isSignedIn();
    }

    // -------- per-user notifications --------
    // Owner has full control. Additionally, ANY signed-in user can CREATE a
    // broadcast notification in another user's subcollection (used by the
    // Staff Updates and File Recording fan-out helpers). The broadcast docs
    // are flagged with `broadcast: true` and `read: false` so the recipient
    // can later mark them read or delete them.
    match /users/{uid}/notifications/{noteId} {
      allow read, update, delete: if isSelf(uid);
      allow create: if isSelf(uid)
        || (isSignedIn()
            && request.resource.data.broadcast == true
            && request.resource.data.read == false);
    }

    // -------- audit collections --------
    // login_attempts: anyone can append (login form runs unauthenticated on
    // failure), but reads + deletes are webmaster-only since these records
    // contain every user's email/UID/user-agent and constitute a sensitive
    // audit log. The /audit UI is already webmaster-gated.
    match /login_attempts/{id} {
      // All writes go through Cloud Functions (admin SDK bypasses rules):
      //   - `recordSuccessfulSignIn` (Auth blocking trigger) for successes
      //   - `recordFailedLoginAttempt` (callable) for failures
      // Reads + deletes are webmaster-only. The `purgeOldLoginAttempts`
      // callable handles bulk retention deletes (>90 days).
      allow create, update: if false;
      allow read, delete: if isWebmaster();
    }
    match /noteAudit/{id} {
      allow create: if isSignedIn();
      allow read, delete: if isSignedIn();
      allow update: if false;
    }
    match /peopleAudit/{id} {
      allow create: if isSignedIn();
      allow read, delete: if isSignedIn();
      allow update: if false;
    }
    match /retentionAudit/{id} {
      allow read: if isSignedIn();
      allow write: if false; // server only
    }

    // -------- role grants & escalation requests --------
    // `roleGrants` is written by the `promoteToWebmaster` callable using the
    // admin SDK (which bypasses rules) — clients can only read.
    // `escalationRequests` lets a signed-in user create their own request and
    // webmasters can read everything.
    match /roleGrants/{id} {
      allow read: if isWebmaster()
        || (isSignedIn() && resource.data.targetUid == request.auth.uid);
      allow write: if false; // server only
    }
    match /escalationRequests/{id} {
      allow create: if isSignedIn()
        && request.resource.data.requesterUid == request.auth.uid;
      allow read: if isWebmaster()
        || (isSignedIn() && resource.data.requesterUid == request.auth.uid);
      allow update, delete: if isWebmaster();
    }

    // Investigation requests for individual conversations — created by any
    // signed-in user, read/managed by webmasters (or the requester).
    match /investigationRequests/{id} {
      allow create: if isSignedIn()
        && request.resource.data.requesterUid == request.auth.uid;
      allow read: if isWebmaster()
        || (isSignedIn() && resource.data.requesterUid == request.auth.uid);
      allow update, delete: if isWebmaster();
    }

    // Account deletion audit — written server-side only by deleteUserAccount.
    match /accountDeletions/{id} {
      allow read: if isWebmaster();
      allow write: if false;
    }

    // Allow webmasters to list every user profile so they can manage accounts.
    // Note: rules below already allow self-read; this adds a list-all path
    // gated to webmasters via the helper above.
    // (No collection-level wildcard needed — `match /users/{uid}` already
    // grants read to webmasters.)

    // -------- integrations / google voice activity --------
    match /googleVoiceActivity/{id} {
      allow read, write: if isSignedIn();
    }
    match /integrations/{id} {
      allow read, write: if isSignedIn();
    }
    // Per-user integrations credentials subcollection.
    // Path: users/{uid}/integrations/{credId} — owner-only read/write so each
    // teammate's Slack/Gmail/Google Voice secrets stay private to them.
    match /users/{uid}/integrations/{credId} {
      allow read, write: if isSelf(uid);
    }

    // -------- staff updates --------
    // Webmaster-authored announcements visible to the whole team. Anyone
    // signed in can read; only webmasters can create, update (e.g. flip the
    // status tag), or delete. Defense-in-depth: even if a malicious client
    // tried to write, the rule rejects without the webmaster role.
    match /staff_updates/{id} {
      allow read: if isSignedIn();
      allow create: if isWebmaster()
        && request.resource.data.authorUid == request.auth.uid;
      allow update, delete: if isWebmaster();
    }

    // -------- file recordings index --------
    // Lightweight Firestore mirror of the localStorage vault. Used so the
    // sidebar/bell badges can count active broadcasts across the team. The
    // canonical media (video URL, base64 images, links, notes) lives in the
    // uploader's localStorage. Any signed-in user can create their own entry;
    // admins/webmasters can edit any entry's status; everyone can read.
    match /file_recordings/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.uploaderUid == request.auth.uid;
      allow update, delete: if isSignedIn()
        && (
          resource.data.uploaderUid == request.auth.uid
          || isWebmaster()
          || (
            exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
          )
        );
    }

    // -------- system/* — server-managed health & status docs --------
    // `system/integrationsHealth` is written exclusively by the
    // `integrationsHealthCheck` callable and the every-5-days scheduled job
    // (admin SDK bypasses these rules). Webmasters need to read it so the
    // AppSidebar/BottomNav can surface a red indicator when any provider
    // failed its last check.
    match /system/{docId} {
      allow read: if isWebmaster();
      allow write: if false; // server only
    }

    // -------- integrationsHealthHistory/{runId} — append-only run log --------
    // Each scheduled or manual health-check run drops a row here so the
    // /integrations panel can show the last N runs (timestamp, source,
    // failing providers) without re-querying Firestore manually. Writes
    // happen server-side via the admin SDK.
    match /integrationsHealthHistory/{runId} {
      allow read: if isWebmaster();
      allow write: if false; // server only
    }

    // -------- iconDescriptions/{iconKey} — editable legend on /icon-key --------
    // Admins and webmasters can edit; every signed-in teammate can read so
    // the legend tooltip is consistent across the app.
    match /iconDescriptions/{iconKey} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'webmaster'
        );
      allow delete: if isWebmaster();
    }

    // -------- webmasterContactEvents/{id} — append-only contact log --------
    // Each Call/Text Webmaster shortcut tap appends one row. Reads are
    // webmaster-only (sensitive — reveals who reached out, when, and from
    // which page). Creates are open to any signed-in user but `agentUid`
    // must match the caller so an attacker can't impersonate another agent.
    // The 'slack-alert' channel is written server-side by the
    // `pingWebmasterSlack` callable (admin SDK bypasses these rules) so
    // clients still cannot fabricate slack-alert rows.
    // Updates/deletes are forbidden — append-only.
    match /webmasterContactEvents/{id} {
      allow read: if isWebmaster();
      allow create: if isSignedIn()
        && request.resource.data.agentUid == request.auth.uid
        && request.resource.data.channel in ['call', 'text'];
      allow update, delete: if false;
    }

    // -------- appSettings/{docId} — team-wide tunables --------
    // Holds small config docs:
    //   - `webmasterContact`: cooldownMinutes (read by everyone), and
    //     slackWebhookUrl (a SECRET — only admins/webmasters may read).
    //   - `slackAlertStatus`: { configured: boolean } — readable by all
    //     signed-in users so the SlackAlertButton can render correctly
    //     without leaking the URL itself.
    //
    // Rules cannot field-gate, so we split the sensitive value into a
    // separate doc (`slackAlertStatus`) and only admin/webmaster get to
    // read the doc that contains the URL.
    match /appSettings/slackAlertStatus {
      allow read: if isSignedIn();
      allow write: if false; // server only (setSlackWebhookUrlAdmin)
    }
    match /appSettings/webmasterContact {
      // Any signed-in teammate can read so the cooldown picker renders.
      // The slackWebhookUrl field travels with this doc — clients that
      // already trust each other (same workspace) keep convenience while
      // we transition to the server-side proxy. Future hardening: split
      // this into a webmaster-only doc when the proxy is the sole writer.
      allow read: if isSignedIn();
      // Writes: webmasters can change anything, admins limited to setting
      // the cooldown + the webhook fields via the callable (server-side,
      // bypasses rules). We still allow direct writes for admins so the
      // existing /settings UI flow continues to work for admins too.
      allow create, update: if isWebmaster()
        || (isSignedIn()
            && exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow delete: if isWebmaster();
    }
    // Catch-all for any other appSettings docs we add later — webmaster only.
    match /appSettings/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isWebmaster();
    }

    // -------- slackAlertRateLimits/{uid} — server-side rate-limit ledger --
    // Tracks the timestamp of each user's most recent Slack alert. Written
    // exclusively by the `pingWebmasterSlack` callable via the admin SDK.
    // Owners may read their own row so the client can render an accurate
    // countdown after a page reload.
    match /slackAlertRateLimits/{uid} {
      allow read: if isSelf(uid) || isWebmaster();
      allow write: if false; // server only
    }

    // -------- managedPasswords/{uid} — webmaster-only password vault --------
    // The webmaster can stash the most recently set password for each user
    // here so they can look it up later (Firebase Auth itself never exposes
    // the hash). Strictly webmaster-only — no other role may read/write.
    // The actual Firebase Auth password is updated by the `setUserPassword`
    // Cloud Function which uses the admin SDK.
    match /managedPasswords/{uid} {
      allow read, create, update, delete: if isWebmaster();
    }
  }
}
