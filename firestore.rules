rules_version = '2';

// =============================================================================
// Kit TJ Services ClientHub Firestore Security Rules
//
// SECURITY MODEL
// - Roles live on `users/{uid}` documents and are NEVER writable from the client
//   except by webmasters. The `role` field is locked down here, and the
//   `enforceUserRoleOnWrite` Cloud Function provides defense-in-depth by
//   stripping any client-supplied `role` field on every write.
// - Only authenticated users can read/write their own profile. Webmasters can
//   read any profile and are the only principals allowed to mutate roles.
// - Audit collections (`login_attempts`, `noteAudit`, `peopleAudit`,
//   `retentionAudit`) are append-only for clients; deletes/clears are gated to
//   authenticated users (admins/webmasters use the UI controls).
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // -------- Helpers --------
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Webmaster check uses the user's own profile doc. Safe from recursion
    // because we only read users/{auth.uid} (no policy back-reference loop).
    function isWebmaster() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'webmaster';
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // True when the signed-in caller has the `customer` role. Customers
    // belong to the public portal — they must never have read/write access
    // to internal collections (audit logs, agent rosters, integrations,
    // notifications fan-out, etc.). Internal-only rules pair `isSignedIn()`
    // with `!isCustomer()`.
    function isCustomer() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'customer';
    }

    // Convenience: any internal teammate role (anything except customer).
    function isInternal() {
      return isSignedIn() && !isCustomer();
    }

    // True when the incoming write does NOT touch the `role` field, OR the
    // value being written matches what's already there.
    function roleUnchanged() {
      return !('role' in request.resource.data)
        || (resource != null && resource.data.role == request.resource.data.role);
    }

    // Same idea for the `escalatedAccess` field — only webmasters may toggle
    // expanded access for an admin.
    function escalatedAccessUnchanged() {
      return !('escalatedAccess' in request.resource.data)
        || (resource != null
            && resource.data.get('escalatedAccess', false) == request.resource.data.escalatedAccess);
    }

    // Same idea for the `supportAccess` field — only webmasters can grant/revoke
    // the Support call-center interface and chat-moderator powers.
    function supportAccessUnchanged() {
      return !('supportAccess' in request.resource.data)
        || (resource != null
            && resource.data.get('supportAccess', false) == request.resource.data.supportAccess);
    }

    // -------- users/{uid} --------
    // Users can read & write their own profile, but cannot set or change
    // `role` or `escalatedAccess`. Webmasters can read any profile and are
    // the only ones allowed to write those privileged fields.
    match /users/{uid} {
      // Any signed-in teammate can read profiles (used to render assignee
      // names in /agents, /conversations, /agent-logs, /analytics, and to
      // fan-out broadcast notifications).
      allow read: if isInternal();

      // Create: self-signup. The Cloud Function strips role; rules also forbid
      // a client-supplied non-default role unless the caller is a webmaster.
      allow create: if isSelf(uid)
        && (
          !('role' in request.resource.data)
          || request.resource.data.role == 'agent'
          || isWebmaster()
        )
        && !('escalatedAccess' in request.resource.data)
        && !('supportAccess' in request.resource.data)
        && (
          !('approvalStatus' in request.resource.data)
          || request.resource.data.approvalStatus == 'pending'
        );

      // Update: self can update profile fields but cannot mutate `role`,
      // `escalatedAccess`, `supportAccess`, or `approvalStatus`. Webmasters
      // and admins can update anything (admins included so they can approve
      // pending signups from Settings).
      allow update: if (
          isSelf(uid)
          && roleUnchanged()
          && escalatedAccessUnchanged()
          && supportAccessUnchanged()
          && (
            !('approvalStatus' in request.resource.data)
            || (resource != null && resource.data.get('approvalStatus', 'approved') == request.resource.data.approvalStatus)
          )
        )
        || isWebmaster()
        || isAdmin();

      // Delete: webmaster only.
      allow delete: if isWebmaster();
    }

    // -------- agentRoster/{id} — signup verification source ----------------
    // Webmaster + admin can read/write; everyone signed in can read so the
    // local-fallback cache stays warm for offline signup verification.
    match /agentRoster/{id} {
      allow read: if isInternal();
      allow create, update, delete: if isWebmaster() || isAdmin();
    }

    // -------- conversations + messages + notes --------
    match /conversations/{convoId} {
      // Internal team: full read/write. Customers: read-only and only if
      // they own the thread (customerUid matches their auth uid).
      allow read: if isInternal()
        || (isCustomer()
            && resource != null
            && resource.data.get('customerUid', '') == request.auth.uid);
      // Customers may only update narrow fields (e.g. unreadByCustomer
      // counter); they cannot mutate routing/ownership. Internal users
      // retain full write access.
      allow create: if isInternal();
      allow update: if isInternal()
        || (isCustomer()
            && resource != null
            && resource.data.get('customerUid', '') == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['unreadByCustomer', 'lastCustomerViewedAt']));
      allow delete: if isInternal();

      match /messages/{msgId} {
        // Same scoping as the parent thread.
        allow read: if isInternal()
          || (isCustomer()
              && get(/databases/$(database)/documents/conversations/$(convoId))
                   .data.get('customerUid', '') == request.auth.uid);
        // Customers cannot create new messages from the portal (the chat
        // widget pipes through `postWidgetMessage` Cloud Function instead).
        allow create: if isInternal();
        // Updates: internal users can mutate freely; customers can ONLY
        // patch the rating fields on an existing message in their thread.
        allow update: if isInternal()
          || (
            isCustomer()
            && get(/databases/$(database)/documents/conversations/$(convoId))
                 .data.get('customerUid', '') == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['rating', 'ratingStars', 'ratingNote', 'ratedByUid', 'ratedAt'])
          );
        allow delete: if isInternal();
      }
      // Conversation notes — internal team only. Customers must never see
      // private agent annotations.
      match /notes/{noteId} {
        allow read, create, update: if isInternal();
        allow delete: if isInternal() && (
          (
            exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && (
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'webmaster'
              || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
            )
          )
        );
      }
    }

    // -------- people --------
    match /people/{personId} {
      allow read, write: if isInternal();
    }

    // -------- customerSignupLog/{id} — admin-visible portal signup log -----
    // Auto-approved customer signups append a row here for visibility. Reads
    // are limited to internal team; create is open to authed signups (the
    // doc carries the caller's own uid for auditing).
    match /customerSignupLog/{id} {
      allow read: if isInternal();
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // -------- widgetActivity/{id} — public-widget telemetry ----------------
    // Written by widget Cloud Functions via admin SDK (admin SDK bypasses
    // rules). Internal team reads for analytics; no client writes.
    match /widgetActivity/{id} {
      allow read: if isInternal();
      allow write: if false;
    }

    // -------- per-user notifications --------
    // Owner has full control. Additionally, ANY signed-in user can CREATE a
    // broadcast notification in another user's subcollection (used by the
    // Staff Updates and File Recording fan-out helpers). The broadcast docs
    // are flagged with `broadcast: true` and `read: false` so the recipient
    // can later mark them read or delete them.
    match /users/{uid}/notifications/{noteId} {
      allow read, update, delete: if isSelf(uid);
      allow create: if isSelf(uid)
        || (isSignedIn()
            && request.resource.data.broadcast == true
            && request.resource.data.read == false);
    }

    // -------- per-user UI preferences --------
    // Cross-device prefs (theme, background Gmail toggle, etc.) live at
    // users/{uid}/prefs/{docId}. Owner-only — nothing here is sensitive but
    // there's no reason for other teammates to read or mutate it. Without
    // this explicit rule, the catch-all denies access and the
    // `subscribeBoolPrefRemote` listener errors out with permission-denied.
    match /users/{uid}/prefs/{docId} {
      allow read, write: if isSelf(uid);
    }

    // -------- audit collections --------
    // login_attempts: anyone can append (login form runs unauthenticated on
    // failure), but reads + deletes are webmaster-only since these records
    // contain every user's email/UID/user-agent and constitute a sensitive
    // audit log. The /audit UI is already webmaster-gated.
    match /login_attempts/{id} {
      // All writes go through Cloud Functions (admin SDK bypasses rules):
      //   - `recordSuccessfulSignIn` (Auth blocking trigger) for successes
      //   - `recordFailedLoginAttempt` (callable) for failures
      // Reads + deletes are webmaster-only. The `purgeOldLoginAttempts`
      // callable handles bulk retention deletes (>90 days).
      allow create, update: if false;
      allow read, delete: if isWebmaster();
    }
    match /noteAudit/{id} {
      allow create: if isSignedIn();
      allow read: if isInternal();
      allow delete: if isWebmaster();
      allow update: if false;
    }
    match /peopleAudit/{id} {
      allow create: if isSignedIn();
      allow read: if isInternal();
      allow delete: if isWebmaster();
      allow update: if false;
    }
    match /retentionAudit/{id} {
      allow read: if isInternal();
      allow write: if false; // server only
    }

    // -------- role grants & escalation requests --------
    // `roleGrants` is written by the `promoteToWebmaster` callable using the
    // admin SDK (which bypasses rules) — clients can only read.
    // `escalationRequests` lets a signed-in user create their own request and
    // webmasters can read everything.
    match /roleGrants/{id} {
      allow read: if isWebmaster()
        || (isSignedIn() && resource.data.targetUid == request.auth.uid);
      allow write: if false; // server only
    }
    match /escalationRequests/{id} {
      allow create: if isSignedIn()
        && request.resource.data.requesterUid == request.auth.uid;
      allow read: if isWebmaster()
        || (isSignedIn() && resource.data.requesterUid == request.auth.uid);
      allow update, delete: if isWebmaster();
    }

    // Investigation requests for individual conversations — created by any
    // signed-in user, read/managed by webmasters (or the requester).
    match /investigationRequests/{id} {
      allow create: if isSignedIn()
        && request.resource.data.requesterUid == request.auth.uid;
      allow read: if isWebmaster()
        || (isSignedIn() && resource.data.requesterUid == request.auth.uid);
      allow update, delete: if isWebmaster();
    }

    // Account deletion audit — written server-side only by deleteUserAccount.
    match /accountDeletions/{id} {
      allow read: if isWebmaster();
      allow write: if false;
    }

    // Allow webmasters to list every user profile so they can manage accounts.
    // Note: rules below already allow self-read; this adds a list-all path
    // gated to webmasters via the helper above.
    // (No collection-level wildcard needed — `match /users/{uid}` already
    // grants read to webmasters.)

    // -------- integrations / google voice activity --------
    match /googleVoiceActivity/{id} {
      allow read, write: if isInternal();
    }
    match /integrations/{id} {
      allow read, write: if isInternal();
    }
    // Per-user integrations credentials subcollection.
    // Path: users/{uid}/integrations/{credId} — owner-only read/write so each
    // teammate's Slack/Gmail/Google Voice secrets stay private to them.
    match /users/{uid}/integrations/{credId} {
      allow read, write: if isSelf(uid);
    }

    // -------- staff updates --------
    // Webmaster-authored announcements visible to the whole team. Anyone
    // signed in can read; only webmasters can create, update (e.g. flip the
    // status tag), or delete. Defense-in-depth: even if a malicious client
    // tried to write, the rule rejects without the webmaster role.
    match /staff_updates/{id} {
      allow read: if isInternal();
      // Webmasters can post any update. Any signed-in user can post a
      // system-generated `flag_alert` (the client-side profanity detector
      // writes these); the rule pins authorUid to the caller and the kind
      // must be exactly "flag_alert" to prevent abuse.
      allow create: if (
        isWebmaster()
        && request.resource.data.authorUid == request.auth.uid
      ) || (
        isSignedIn()
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.get('kind', '') == 'flag_alert'
      );
      // Webmasters can update any field. Any signed-in user may update
      // ONLY the review-tracking fields on an existing flag_alert
      // (reviewStatus / resolutionNotes / reviewedBy / reviewedAt) so the
      // team can triage alerts without needing webmaster role.
      allow update: if isWebmaster() || (
        isSignedIn()
        && resource != null
        && resource.data.get('kind', '') == 'flag_alert'
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['reviewStatus','resolutionNotes','reviewedBy','reviewedAt','reviewedByName'])
      );
      allow delete: if isWebmaster();
    }

    // -------- flagged terms (profanity / abuse wordlist) --------
    // Editable wordlist used by the client-side flagger. Any signed-in user
    // needs to read the list (to scan their outgoing messages); only
    // webmasters can add or remove terms.
    match /flagged_terms/{id} {
      allow read: if isInternal();
      allow create, update, delete: if isWebmaster();
    }

    // -------- file recordings index --------
    // Lightweight Firestore mirror of the localStorage vault. Used so the
    // sidebar/bell badges can count active broadcasts across the team. The
    // canonical media (video URL, base64 images, links, notes) lives in the
    // uploader's localStorage. Any signed-in user can create their own entry;
    // admins/webmasters can edit any entry's status; everyone can read.
    match /file_recordings/{id} {
      allow read: if isInternal();
      allow create: if isSignedIn()
        && request.resource.data.uploaderUid == request.auth.uid;
      allow update, delete: if isSignedIn()
        && (
          resource.data.uploaderUid == request.auth.uid
          || isWebmaster()
          || (
            exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
          )
        );
    }

    // -------- system/* — server-managed health & status docs --------
    // `system/integrationsHealth` is written exclusively by the
    // `integrationsHealthCheck` callable and the every-5-days scheduled job
    // (admin SDK bypasses these rules). Webmasters need to read it so the
    // AppSidebar/BottomNav can surface a red indicator when any provider
    // failed its last check.
    match /system/{docId} {
      allow read: if isWebmaster();
      allow write: if false; // server only
    }

    // -------- integrationsHealthHistory/{runId} — append-only run log --------
    // Each scheduled or manual health-check run drops a row here so the
    // /integrations panel can show the last N runs (timestamp, source,
    // failing providers) without re-querying Firestore manually. Writes
    // happen server-side via the admin SDK.
    match /integrationsHealthHistory/{runId} {
      allow read: if isWebmaster();
      allow write: if false; // server only
    }

    // -------- iconDescriptions/{iconKey} — editable legend on /icon-key --------
    // Admins and webmasters can edit; every signed-in teammate can read so
    // the legend tooltip is consistent across the app.
    match /iconDescriptions/{iconKey} {
      allow read: if isInternal();
      allow create, update: if isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'webmaster'
        );
      allow delete: if isWebmaster();
    }

    // -------- webmasterContactEvents/{id} — append-only contact log --------
    // Each Call/Text Webmaster shortcut tap appends one row. Reads are
    // webmaster-only (sensitive — reveals who reached out, when, and from
    // which page). Creates are open to any signed-in user but `agentUid`
    // must match the caller so an attacker can't impersonate another agent.
    // The 'slack-alert' channel is written server-side by the
    // `pingWebmasterSlack` callable (admin SDK bypasses these rules) so
    // clients still cannot fabricate slack-alert rows.
    // Updates/deletes are forbidden — append-only.
    match /webmasterContactEvents/{id} {
      allow read: if isWebmaster();
      allow create: if isSignedIn()
        && request.resource.data.agentUid == request.auth.uid
        && request.resource.data.channel in ['call', 'text'];
      allow update, delete: if false;
    }

    // -------- appSettings/{docId} — team-wide tunables --------
    // Holds small config docs:
    //   - `webmasterContact`: cooldownMinutes (read by everyone), and
    //     slackWebhookUrl (a SECRET — only admins/webmasters may read).
    //   - `slackAlertStatus`: { configured: boolean } — readable by all
    //     signed-in users so the SlackAlertButton can render correctly
    //     without leaking the URL itself.
    //
    // Rules cannot field-gate, so we split the sensitive value into a
    // separate doc (`slackAlertStatus`) and only admin/webmaster get to
    // read the doc that contains the URL.
    match /appSettings/slackAlertStatus {
      allow read: if isInternal();
      allow write: if false; // server only (setSlackWebhookUrlAdmin)
    }
    // Slack incoming-webhook URL — webmaster-only read, server-only write.
    // The `setSlackWebhookUrlAdmin` callable writes here via the admin SDK
    // (which bypasses these rules). Agents and admins must NEVER be able to
    // read this doc; the public `slackAlertStatus` mirror exposes only a
    // boolean for UI purposes.
    match /appSettings/slackWebhookSecret {
      allow read: if isWebmaster();
      allow write: if false;
    }
    match /appSettings/webmasterContact {
      // Any signed-in teammate can read so the cooldown picker renders.
      // The slackWebhookUrl field travels with this doc — clients that
      // already trust each other (same workspace) keep convenience while
      // we transition to the server-side proxy. Future hardening: split
      // this into a webmaster-only doc when the proxy is the sole writer.
      allow read: if isInternal();
      // Writes: webmasters can change anything, admins limited to setting
      // the cooldown + the webhook fields via the callable (server-side,
      // bypasses rules). We still allow direct writes for admins so the
      // existing /settings UI flow continues to work for admins too.
      allow create, update: if isWebmaster()
        || (isSignedIn()
            && exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow delete: if isWebmaster();
    }
    // Call recording retention policy — admins + webmasters can edit.
    // Everyone signed in needs to read so the consent banner renders.
    match /appSettings/callRecordings {
      allow read: if isInternal();
      allow create, update: if isWebmaster()
        || (isSignedIn()
            && exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow delete: if isWebmaster();
    }
    // Catch-all for any other appSettings docs we add later — webmaster only.
    // IMPORTANT: read is webmaster-only so this rule does NOT widen access to
    // sensitive docs like `slackWebhookSecret`. Docs that need broader read
    // access must declare their own explicit `match` block above.
    match /appSettings/{docId} {
      allow read: if isWebmaster();
      allow create, update, delete: if isWebmaster();
    }
    // -------- slackAlertRateLimits/{uid} — server-side rate-limit ledger --
    // Tracks the timestamp of each user's most recent Slack alert. Written
    // exclusively by the `pingWebmasterSlack` callable via the admin SDK.
    // Owners may read their own row so the client can render an accurate
    // countdown after a page reload.
    match /slackAlertRateLimits/{uid} {
      allow read: if isSelf(uid) || isWebmaster();
      allow write: if false; // server only
    }

    // -------- managedPasswords/{uid} — webmaster-only password vault --------
    // The webmaster can stash the most recently set password for each user
    // here so they can look it up later (Firebase Auth itself never exposes
    // the hash). Strictly webmaster-only — no other role may read/write.
    // The actual Firebase Auth password is updated by the `setUserPassword`
    // Cloud Function which uses the admin SDK.
    match /managedPasswords/{uid} {
      allow read, create, update, delete: if isWebmaster();
    }

    // -------- chatThreads/{threadId} — internal team DM threads --------------
    // Two-participant DMs (no group chats yet). Each thread doc lists the
    // exact participant uids; only those users can read or write.
    //
    // Moderation = role admin/webmaster OR the support@convohub.dev account.
    // Mirrored client-side in `canModerateChat()` (src/lib/chat.ts).
    function isChatModerator() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'webmaster'
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email == 'support@convohub.dev'
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('supportAccess', false) == true
        );
    }

    match /chatThreads/{threadId} {
      // Read: only listed participants.
      allow read: if isSignedIn()
        && request.auth.uid in resource.data.participantUids;

      // Create: caller must be one of the participants. We don't restrict
      // size so the model can later grow into group chats.
      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participantUids
        && request.resource.data.createdByUid == request.auth.uid;

      // Update: participants may only modify a strict whitelist of
      // non-membership metadata fields. The participant list, creator, and
      // any other field that could grant new access or change identity are
      // locked from the client. Moderators flip `archived` via the same
      // path. All other field changes are blocked here.
      allow update: if isSignedIn()
        && request.auth.uid in resource.data.participantUids
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'lastMessagePreview',
          'lastMessageAt',
          'lastMessageSenderUid',
          'updatedAt',
          'archived',
          'archivedByUid',
          'archivedAt',
          'readState',
          'typingState'
        ]);

      // Hard delete: forbidden — moderators use soft-archive via update.
      allow delete: if false;

      match /messages/{messageId} {
        // Read: any participant of the parent thread.
        allow read: if isSignedIn()
          && request.auth.uid in
             get(/databases/$(database)/documents/chatThreads/$(threadId)).data.participantUids;

        // Create: caller must be a participant AND must stamp themselves
        // as senderUid (no impersonation).
        allow create: if isSignedIn()
          && request.auth.uid in
             get(/databases/$(database)/documents/chatThreads/$(threadId)).data.participantUids
          && request.resource.data.senderUid == request.auth.uid
          && request.resource.data.deleted == false;

        // Update splits two cases:
        //   1. Original sender editing their own message body (sets editedAt).
        //   2. Moderator soft-deleting (sets deleted=true, clears body).
        // Either path requires the immutable identity fields to stay put.
        allow update: if isSignedIn()
          && resource.data.senderUid != null
          && request.resource.data.senderUid == resource.data.senderUid
          && (
            // own-edit
            (
              resource.data.senderUid == request.auth.uid
              && resource.data.deleted != true
              && request.resource.data.deleted == resource.data.deleted
            )
            // moderator soft-delete
            || (
              isChatModerator()
              && request.resource.data.deleted == true
            )
          );

        // Hard delete: forbidden — soft-delete via the update path above.
        allow delete: if false;
      }
    }

    // -------- widgetConfigs/{tenantId} — embeddable widget tenant config --
    // Stores public siteKey, theme, and allowedOrigins for each tenant that
    // installs the chat widget. siteKey is public (travels in the <script>
    // tag) — security comes from the (siteKey, allowedOrigins) pair enforced
    // server-side in createWidgetConversation/postWidgetMessage.
    // Reads: any signed-in teammate (admin UI lists configs).
    // Writes: admins + webmasters only.
    match /widgetConfigs/{tenantId} {
      allow read: if isInternal();
      allow create, update: if isWebmaster() || isAdmin();
      allow delete: if isWebmaster();
    }

    // -------- widgetIpRateLimits/{ipHash} — server-side widget IP ledger ---
    // Written exclusively by the widget Cloud Functions (admin SDK bypass).
    match /widgetIpRateLimits/{ipHash} {
      allow read, write: if false; // server only
    }

    // -------- widgetRateLimits/{tokenHash} — per-token rate ledger ---------
    match /widgetRateLimits/{tokenHash} {
      allow read, write: if false; // server only
    }

    // -------- callRecordings/{id} — call recording metadata --------
    // Storage objects live in Firebase Storage at call_recordings/{convoId}/*.
    // Firestore docs hold the metadata used by the analytics dashboard.
    // Reads: any signed-in teammate (call analytics is team-wide).
    // Create: signed-in user creating their own row (agentUid match).
    // Update/Delete: own recording, OR admin/webmaster.
    match /callRecordings/{id} {
      allow read: if isSignedIn()
        && (resource.data.agentUid == request.auth.uid || isAdmin() || isWebmaster());
      allow create: if isSignedIn()
        && request.resource.data.agentUid == request.auth.uid
        && (!('downloadUrl' in request.resource.data) || request.resource.data.downloadUrl == '');
      allow update, delete: if isSignedIn()
        && (
          resource.data.agentUid == request.auth.uid
          || isWebmaster()
          || (
            exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
          )
        );
    }

    // -------- security_findings/{id} — webmaster security dashboard --------
    // Tracks known security findings (severity, status, affected collections,
    // re-scan timestamps). Webmaster-only — no other role can read or write.
    match /security_findings/{id} {
      allow read, create, update, delete: if isWebmaster();
    }

    // -------- security_alerts/{id} — append-only alert stream --------
    // Suspicious activity: failed login streaks, privilege-flag write
    // attempts, etc. Written by Cloud Functions (admin SDK bypass) and by
    // any signed-in user reporting their own client-side detection (e.g.
    // the AuthContext failed-login path). Webmaster-only reads/deletes.
    match /security_alerts/{id} {
      allow create: if isSignedIn();
      allow read, delete: if isWebmaster();
      allow update: if false;
    }
  }
}
