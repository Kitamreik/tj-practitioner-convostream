rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /call_recordings/{conversationId}/{filename} {
      allow read: if false;
      allow create, update: if request.auth != null
        && request.resource.size < 50 * 1024 * 1024
        && request.resource.contentType.matches("audio/.*");
      allow delete: if false;
    }

    // Conversation document uploads (PDF/DOCX/etc) attached by agents.
    // Bytes are kept at most 6 hours; a scheduled Cloud Function
    // (purgeConversationUploads) sweeps anything past customMetadata.deleteAt.
    // Browser reads are denied — only the masked summary in the message thread
    // is surfaced to agents. 10 MB cap, agent must be signed in.
    match /conversation-uploads/{conversationId}/{filename} {
      allow read: if false;
      allow create, update: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024;
      allow delete: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
