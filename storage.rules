rules_version = '2';

// Firebase Storage rules for ConvoHub.
// Default-deny everything; explicitly allow the call recording path.
service firebase.storage {
  match /b/{bucket}/o {
    // Call recordings live at call_recordings/{conversationId}/{recordingId}.{ext}
    // Reads: any signed-in teammate (Call Analytics surfaces play/download links).
    // Writes: signed-in users only (agent uploading their own recording);
    //   the matching Firestore doc enforces agentUid == request.auth.uid.
    // Size cap: 50 MB per recording (≈ 1+ hour of opus audio at 64kbps).
    match /call_recordings/{conversationId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 50 * 1024 * 1024
        && request.resource.contentType.matches("audio/.*");
      allow delete: if request.auth != null;
    }

    // Default-deny anything else.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
