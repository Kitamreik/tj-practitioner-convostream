rules_version = '2';

// Firebase Storage rules for ConvoHub.
// Default-deny everything; explicitly allow the call recording path.
service firebase.storage {
  match /b/{bucket}/o {
    // Call recordings live at call_recordings/{conversationId}/{recordingId}.{ext}
    // Reads are denied to browsers. Authorized users request short-lived links
    // through the getCallRecordingDownloadUrl callable, which checks role + owner.
    // Writes: signed-in users only; Firestore metadata enforces agentUid ownership.
    // Size cap: 50 MB per recording (≈ 1+ hour of opus audio at 64kbps).
    match /call_recordings/{conversationId}/{filename} {
      allow read: if false;
      allow write: if request.auth != null
        && request.resource.size < 50 * 1024 * 1024
        && request.resource.contentType.matches("audio/.*");
      allow delete: if false;
    }

    // Default-deny anything else.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
